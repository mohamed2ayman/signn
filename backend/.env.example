# SIGN Platform - NestJS Backend Environment Variables
# Copy this file to .env and fill in the values before starting the server.
# Required vars will cause startup to FAIL FAST with a clear error if missing.

# ── Core App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://sign_user:password@localhost:5432/sign_db

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-16-chars
# JWT_REFRESH_SECRET — must be DIFFERENT from JWT_SECRET, minimum 32 chars.
# Required at startup. Falling back to JWT_SECRET would defeat the purpose
# of having a separate signing key for refresh tokens.
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-minimum-32-chars-required
# Phase 4.2 — env-driven token lifetimes (replaces hardcoded '15m'/'7d')
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# DEPRECATED — kept for backward compat, do not delete yet
JWT_EXPIRES_IN=7d
NESTJS_INTERNAL_TOKEN=your-internal-token-here

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Rate Limiting ─────────────────────────────────────────────
# Throttler uses the same REDIS_URL as Bull queues — no separate Redis needed.
# Thresholds are configured in app.module.ts → ThrottlerModule.forRootAsync().
# See CLAUDE.md → "Rate Limiting Policy" for the canonical table and the
# procedure for changing a limit safely.

# ── Frontend ──────────────────────────────────────────────────
# In production, comma-separate multiple origins: https://sign.ai,https://managex.ai
# The CORS config in main.ts already handles splitting on comma (see Phase 6.9).
FRONTEND_URL=http://localhost:5173
# Backend base URL (used for generating links in emails and PDFs)
BASE_URL=http://localhost:3000

# ── AI Backend ────────────────────────────────────────────────
AI_BACKEND_URL=http://ai-backend:8000

# ── Anthropic AI (optional) ───────────────────────────────────
ANTHROPIC_API_KEY=

# ── DocuSign (optional — configure when sandbox is ready) ─────
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_WEBHOOK_HMAC_SECRET=

# ─── DocuSign JWT Grant ───────────────────────────────────────────────────────
# Required only when DocuSign integration is active.
# DOCUSIGN_RSA_PRIVATE_KEY: paste the full RSA private key (PEM format, multiline).
#   In production, ensure newlines are preserved (use \n escapes if your secrets
#   store flattens to one line, or use a multiline-aware secret manager).
# DOCUSIGN_INTEGRATION_KEY, DOCUSIGN_SECRET_KEY, DOCUSIGN_ACCOUNT_ID already
# documented above.
DOCUSIGN_RSA_PRIVATE_KEY=
DOCUSIGN_AUTH_SERVER=https://account-d.docusign.com
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_USER_ID=

# ── Paymob (optional — configure when test keys are ready) ────
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# ── AWS / S3 (optional — configure for production) ────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ── Email / SMTP (optional — configure for production) ────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=

# ─── Email ────────────────────────────────────────────────────────────────────
# Sender address for all outgoing emails.
FROM_EMAIL=noreply@sign.ai

# ─── File Storage ─────────────────────────────────────────────────────────────
# Local path for uploaded files. In production, use S3 (Phase 9).
UPLOAD_DIR=./uploads

# ─── Encryption at rest (Phase 7.28 prerequisite) ─────────────────────────────
# Master key for the AES-256-GCM CryptoService (common/utils/crypto.ts) — the
# first encryption-at-rest primitive in the codebase. Its first consumer is ERP
# credential storage; the util itself is generic (encrypts/decrypts any string).
#
# OPTIONAL at boot — the app starts fine without it, like the other optional
# integration secrets. But CryptoService throws a clear error if encrypt/decrypt
# is called while it is unset, so it MUST be configured before any feature that
# stores encrypted data is enabled.
#
# Must be MIN 32 characters (defensive entropy floor — Joi rejects a shorter
# non-empty value). The configured string is SHA-256-derived to a 32-byte key.
# Generate a high-entropy value — do NOT use a memorable passphrase
# (the key is fast-hashed, so a guessable phrase is brute-forceable):
#   openssl rand -base64 48
# Rotating it makes all previously-encrypted payloads undecryptable, so plan a
# re-encryption migration before rotating.
ERP_CREDENTIAL_ENC_KEY=

# ─── Seed Passwords ───────────────────────────────────────────────────────────
# Required ONLY when running seed scripts (npm run seed:run).
# Not needed for normal app startup.
# Minimum 12 characters. Use a strong password — these become real admin accounts.
SEED_ADMIN_PASSWORD_1=
SEED_ADMIN_PASSWORD_2=
SEED_ADMIN_PASSWORD_3=

# ─── Portfolio Export (Phase 7.17 Prompt 2c) ──────────────────────────────────
# HMAC secret for token-gated PDF download links from /api/v1/portfolio-exports.
# Must be MIN 32 characters — Joi validates at startup, app refuses to boot
# below the floor.
#
# CRITICAL SECURITY NOTE: the download endpoint at GET /portfolio-exports/download
# has NO JWT layer behind it (verified in Phase 7.17 Prompt 2c §3 #11 — there is
# no global JwtAuthGuard registered; auth is opt-in per-controller, and the
# download controller does not opt in). This secret is the ENTIRE security
# floor for that endpoint. A weak or empty value = every token validates =
# org-wide contract financials downloadable by anyone with a crafted URL.
#
# Rotation: rotate by replacing the value. All in-flight tokens become invalid
# immediately. Tokens are 1h-TTL so the user-facing impact is minutes.
PORTFOLIO_EXPORT_DOWNLOAD_SECRET=your-portfolio-export-download-secret-minimum-32-chars

# ─── Guest Portal (Phase 7.18 bucket 1b-i) ──────────────────────────────────
# HMAC secret for the LONG-LIVED guest-invitation token (the value
# emailed to the recipient). REQUIRED, min 32 chars. Verify-before-DB
# in InvitationTokenService.
GUEST_INVITE_SECRET=your-guest-invite-secret-minimum-32-chars-replace-me
# HMAC secret for the SHORT-LIVED viewer credential issued at exchange
# time. The recipient carries it as Authorization: Viewer <token> on
# contract reads. REQUIRED, min 32 chars. MUST differ from
# GUEST_INVITE_SECRET so a compromise of one does not bridge to the other.
GUEST_VIEWER_SECRET=your-guest-viewer-secret-minimum-32-chars-replace-me
# Invitation TTL in days (ops-configurable). Default 30. Range 1–365.
GUEST_INVITE_TTL_DAYS=30
# Viewer credential TTL in minutes. Default 15. Range 1–240. Short by
# design — the viewer is a pre-password read credential, not a session.
GUEST_VIEWER_TTL_MINUTES=15
