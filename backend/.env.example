# SIGN Platform - NestJS Backend Environment Variables

# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://sign_user:sign_password@localhost:5432/sign_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS S3 (file storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=sign-platform-files

# Storage Type (local or s3)
STORAGE_TYPE=local
UPLOAD_DIR=./uploads

# AWS SES (email)
AWS_SES_FROM_EMAIL=noreply@sign-platform.com

# SMTP (dev email - use instead of SES in development)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sign-platform.com

# AI Backend
AI_BACKEND_URL=http://localhost:8000

# Paymob Payment
PAYMOB_API_KEY=
PAYMOB_IFRAME_ID=
PAYMOB_INTEGRATION_ID=
PAYMOB_HMAC_SECRET=

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173
