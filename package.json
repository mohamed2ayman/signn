{
  "name": "managex",
  "version": "1.0.0",
  "private": true,
  "description": "MANAGEX — AI project management platform for construction",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:sign": "npm -w @managex/sign run dev",
    "dev:managex": "npm -w @managex/landing run dev",
    "dev:all": "concurrently -n sign,managex -c blue,cyan \"npm run dev:sign\" \"npm run dev:managex\"",
    "build:sign": "npm -w @managex/sign run build",
    "build:managex": "npm -w @managex/landing run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohamed2ayman/signn.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mohamed2ayman/signn/issues"
  },
  "homepage": "https://github.com/mohamed2ayman/signn#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
