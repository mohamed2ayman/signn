{
  "name": "sign-word-addin",
  "version": "0.1.0",
  "private": true,
  "description": "SIGN for Word — contract intelligence inside Microsoft Word.",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev": "webpack serve --mode development",
    "start": "office-addin-debugging start manifest.localhost.xml",
    "stop": "office-addin-debugging stop manifest.localhost.xml",
    "validate": "office-addin-manifest validate manifest.localhost.xml",
    "package": "node scripts/package.js",
    "generate-icons": "node scripts/generate-icons.js",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.54.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.421",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "archiver": "^7.0.1",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "eslint": "^8.56.0",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^6.0.7",
    "office-addin-dev-certs": "^2.0.7",
    "office-addin-manifest": "^2.1.3",
    "sharp": "^0.34.5",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
