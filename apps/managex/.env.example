# MANAGEX Landing Page Environment Variables

# SIGN App URL (used for "Sign in" / "Get started" / SIGN product card links)
VITE_SIGN_APP_URL=http://localhost:5173

# SIGN Backend API URL (used for the "Notify Me" waitlist form on Coming Soon cards)
# lesson #83: if this var is missing, the URL silently becomes "undefined/api/v1/waitlist"
# In production: https://api.sign.ai/api/v1
VITE_API_URL=http://localhost:3000/api/v1
