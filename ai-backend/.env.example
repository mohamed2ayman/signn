# SIGN Platform - AI Backend (FastAPI) Environment Variables

# Claude API (for all AI agents: Risk Analyzer, Summarizer, DIFF, Obligations, Chat, Research)
ANTHROPIC_API_KEY=

# Claude model id used by ALL agents (single source of truth — Phase 8.1).
# Defaults to claude-sonnet-4-6 in settings.py; override here only after running
# the Arabic accuracy suite (ai-backend/tests/accuracy/) — never swap blind.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Max concurrent chunk-extraction Anthropic calls for ONE large document
# (parallel clause extraction). Default 3 — a safe floor for typical rate
# limits. The platform-wide worst case is (Celery --concurrency) × this value,
# since the rate-limit budget is shared across workers. The agent reads the
# live anthropic-ratelimit-* headers and pauses near the limit, so raising this
# is safe but should be tuned to the account's Anthropic usage tier.
CLAUSE_EXTRACT_CONCURRENCY=3

# OpenAI API (for embeddings only - text-embedding-3-small)
OPENAI_API_KEY=

# Database (read-only access to main PostgreSQL)
DATABASE_URL=postgresql://sign_user:sign_password@localhost:5432/sign_db

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379

# NestJS Backend (for internal API calls)
NESTJS_API_URL=http://localhost:3000/api/v1

# Shared secret for authenticated internal calls between services
NESTJS_INTERNAL_TOKEN=your-internal-shared-secret-change-in-production
