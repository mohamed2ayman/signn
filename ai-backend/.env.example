# SIGN Platform - AI Backend (FastAPI) Environment Variables

# Claude API (for all AI agents: Risk Analyzer, Summarizer, DIFF, Obligations, Chat, Research)
ANTHROPIC_API_KEY=

# OpenAI API (for embeddings only - text-embedding-3-small)
OPENAI_API_KEY=

# Database (read-only access to main PostgreSQL)
DATABASE_URL=postgresql://sign_user:sign_password@localhost:5432/sign_db

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379

# NestJS Backend (for internal API calls)
NESTJS_API_URL=http://localhost:3000/api/v1

# Shared secret for authenticated internal calls between services
NESTJS_INTERNAL_TOKEN=your-internal-shared-secret-change-in-production
